{
    "name": "your-vendor/chronos",
    "description": "An elegant PHP date/time manipulation library similar to Carbon",
    "keywords": ["date", "time", "datetime", "carbon", "laravel", "timestamp", "timezone"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Chronos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chronos\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chronos\\ChronosServiceProvider"
            ],
            "aliases": {
                "Chronos": "Chronos\\Facades\\Chronos"
            }
        }
    }
}
