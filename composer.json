{
    "name": "ChenHT12306/chronos",
    "description": "一个优雅的 PHP 日期时间处理库，类似 Carbon，提供链式调用和丰富的时间操作方法",
    "keywords": [
        "date",
        "time",
        "datetime",
        "carbon",
        "laravel",
        "timestamp",
        "timezone"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Hunter Chan",
            "email": "1261660791@qq.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Chronos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chronos\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix src",
        "cs-check": "php-cs-fixer fix src --dry-run --diff"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chronos\\ChronosServiceProvider"
            ],
            "aliases": {
                "Chronos": "Chronos\\Facades\\Chronos"
            }
        }
    }
}
